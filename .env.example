# ===== Supabase =====
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Drizzle Migrations / Server-side Postgres connection
# Supabase Dashboard > Project Settings > Database > Connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ===== App =====
# Comma-separated list of emails allowed to log in (許可制)
ALLOWED_EMAILS=you@example.com

# Public URL of the deployed app. http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
